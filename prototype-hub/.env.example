# ──────────────────────────────────────────────────────────────────
# Required: Authentication
# ──────────────────────────────────────────────────────────────────

# Shared password your content team will use to log in.
# Pick something memorable but not guessable. Share via 1Password.
SUBMIT_PASSWORD=change-me-to-something-real

# Random secret used to sign auth cookies. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=replace-with-32-byte-random-hex-string


# ──────────────────────────────────────────────────────────────────
# Required: GitHub
# ──────────────────────────────────────────────────────────────────

# Personal access token (classic) with `repo` scope, OR a fine-grained
# token scoped to the prototype repo with Contents: read & write.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The repo where prototypes will be committed (this same repo).
# Format: owner/repo (e.g. levelall/prototype-hub)
GITHUB_REPO=your-org/prototype-hub

# Branch to commit to. Vercel auto-deploys on push to this branch.
GITHUB_BRANCH=main


# ──────────────────────────────────────────────────────────────────
# Required: Notion
# ──────────────────────────────────────────────────────────────────

# Internal integration token from https://www.notion.so/profile/integrations
# Create an integration, then share your hub database with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database ID of your Prototype Hub database.
# Find it in the database URL: notion.so/{workspace}/{DATABASE_ID}?v=...
# Strip the dashes if you want; either format works.
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ──────────────────────────────────────────────────────────────────
# Required: Public URL
# ──────────────────────────────────────────────────────────────────

# The production URL of this app. Used to construct the public prototype
# URL written into Notion. No trailing slash.
NEXT_PUBLIC_BASE_URL=https://prototypes.your-domain.com
